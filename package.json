{
  "name": "obsidian-claude-conduit",
  "version": "1.7.0",
  "description": "Native Obsidian plugin for Claude — vault-aware chat, diff-first writes, organization + curator engines, activity stream, MCP bridge.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "version-bump": "node scripts/version-bump.mjs",
    "release": "npm run build && npm run test && npm run version-bump"
  },
  "keywords": [
    "obsidian-md",
    "obsidian-plugin",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "knowledge-management",
    "rag",
    "embeddings"
  ],
  "author": "GengyveUSA",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gengyveusa/obsidian-claude-conduit.git"
  },
  "bugs": {
    "url": "https://github.com/gengyveusa/obsidian-claude-conduit/issues"
  },
  "homepage": "https://github.com/gengyveusa/obsidian-claude-conduit#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.0",
    "@huggingface/inference": "^4.13.15",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sql.js": "1.14.1",
    "yaml": "2.8.4",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.17",
    "@types/sql.js": "1.4.11",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "builtin-modules": "4.0.0",
    "esbuild": "0.24.2",
    "eslint": "9.39.4",
    "obsidian": "1.12.3",
    "prettier": "3.8.3",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
